# ============================================================================
# Multi-Agent Reasoning System - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
#
# This system supports multiple LLM providers. Configure your preferred provider
# by setting MAS_LLM_PROVIDER and the corresponding API key below.

# ----------------------------------------------------------------------------
# LLM Provider Selection
# ----------------------------------------------------------------------------
# Choose your LLM provider: anthropic, openai, azure_openai, google, mistral, cohere, together, custom
MAS_LLM_PROVIDER=anthropic

# ----------------------------------------------------------------------------
# Anthropic (Claude) Configuration
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: For proxy or API gateway
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ----------------------------------------------------------------------------
# OpenAI Configuration
# ----------------------------------------------------------------------------
# OPENAI_API_KEY=your_openai_api_key_here
# Optional: For custom endpoint (e.g., proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: Organization ID
# OPENAI_ORGANIZATION=org-your_id_here

# ----------------------------------------------------------------------------
# Azure OpenAI Configuration
# ----------------------------------------------------------------------------
# AZURE_OPENAI_API_KEY=your_azure_api_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Optional: Default deployment name
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name

# ----------------------------------------------------------------------------
# Google (Gemini) Configuration
# ----------------------------------------------------------------------------
# GOOGLE_API_KEY=your_google_api_key_here
# Optional: For Vertex AI
# GOOGLE_PROJECT_ID=your_project_id
# GOOGLE_LOCATION=us-central1

# ----------------------------------------------------------------------------
# Mistral AI Configuration
# ----------------------------------------------------------------------------
# MISTRAL_API_KEY=your_mistral_api_key_here
# Optional: For custom endpoint
# MISTRAL_BASE_URL=https://api.mistral.ai

# ----------------------------------------------------------------------------
# Cohere Configuration
# ----------------------------------------------------------------------------
# COHERE_API_KEY=your_cohere_api_key_here
# Optional: For custom endpoint
# COHERE_BASE_URL=https://api.cohere.ai

# ----------------------------------------------------------------------------
# Together AI Configuration
# ----------------------------------------------------------------------------
# TOGETHER_API_KEY=your_together_api_key_here
# Optional: For custom endpoint
# TOGETHER_BASE_URL=https://api.together.xyz

# ----------------------------------------------------------------------------
# Custom/OpenAI-Compatible Endpoint Configuration
# ----------------------------------------------------------------------------
# For any OpenAI-compatible API (local models, other providers, etc.)
# CUSTOM_API_KEY=your_custom_api_key_here
# CUSTOM_BASE_URL=https://your-custom-endpoint.com/v1
# Optional: Prefix to add to model names
# CUSTOM_MODEL_PREFIX=

# ----------------------------------------------------------------------------
# Optional: Model Configuration (Overrides)
# ----------------------------------------------------------------------------
# These override the default model mappings for your chosen provider.
# If not set, sensible defaults are used based on MAS_LLM_PROVIDER.

# Default model for agents
MAS_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Per-agent model overrides (optional)
MAS_ORCHESTRATOR_MODEL=claude-3-5-opus-20240507
MAS_COUNCIL_MODEL=claude-3-5-opus-20240507
MAS_ANALYST_MODEL=claude-3-5-sonnet-20241022
MAS_PLANNER_MODEL=claude-3-5-sonnet-20241022
MAS_CLARIFIER_MODEL=claude-3-5-haiku-20241022
MAS_RESEARCHER_MODEL=claude-3-5-sonnet-20241022
MAS_EXECUTOR_MODEL=claude-3-5-sonnet-20241022
MAS_CODE_REVIEWER_MODEL=claude-3-5-sonnet-20241022
MAS_VERIFIER_MODEL=claude-3-5-opus-20240507
MAS_CRITIC_MODEL=claude-3-5-opus-20240507
MAS_REVIEWER_MODEL=claude-3-5-opus-20240507
MAS_FORMATTER_MODEL=claude-3-5-sonnet-20241022
MAS_MEMORY_CURATOR_MODEL=claude-3-5-sonnet-20241022
MAS_SME_MODEL=claude-3-5-sonnet-20241022

# ----------------------------------------------------------------------------
# Optional: Budget and Cost Control
# ----------------------------------------------------------------------------
# Maximum session budget in USD (default: $5.00)
MAS_MAX_BUDGET=5.00

# Budget warning threshold (default: 80% of max_budget)
MAS_BUDGET_WARNING_THRESHOLD=0.8

# ----------------------------------------------------------------------------
# Optional: Agent Configuration
# ----------------------------------------------------------------------------
# Maximum turns per agent before timeout
MAS_MAX_TURNS_ORCHESTRATOR=200
MAS_MAX_TURNS_SUBAGENT=30
MAS_MAX_TURNS_EXECUTOR=50

# Maximum number of SME personas to spawn per task (default: 3)
MAS_MAX_SME_COUNT=3

# Auto-spawn SMEs based on task analysis (default: true)
MAS_SME_AUTO_SPAWN=true

# ----------------------------------------------------------------------------
# Optional: Logging Configuration
# ----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
MAS_LOG_LEVEL=INFO

# Log format: json, text (default: json)
MAS_LOG_FORMAT=json

# Log file path (optional, default: stdout)
# MAS_LOG_FILE=logs/multi-agent-system.log

# ----------------------------------------------------------------------------
# Optional: UI Configuration
# ----------------------------------------------------------------------------
# Streamlit configuration
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# ----------------------------------------------------------------------------
# Optional: Session Management
# ----------------------------------------------------------------------------
# Session timeout in minutes (default: 60)
MAS_SESSION_TIMEOUT=60

# Enable session persistence (default: true)
MAS_SESSION_PERSISTENCE=true

# ----------------------------------------------------------------------------
# Optional: Feature Flags
# ----------------------------------------------------------------------------
# Enable/disable specific agents
MAS_ENABLE_COUNCIL=true
MAS_ENABLE_SME=true
MAS_ENABLE_CODE_REVIEWER=true
MAS_ENABLE_MEMORY_CURATOR=true

# Enable/disable specific features
MAS_ENABLE_DEBATE=true
MAS_ENABLE_ENSEMBLE=true
MAS_ENABLE_COST_TRACKING=true

# ----------------------------------------------------------------------------
# Optional: Integration Tests
# ----------------------------------------------------------------------------
# Set to true to run integration tests with live API calls
MAS_RUN_INTEGRATION=false

# ----------------------------------------------------------------------------
# Development Settings
# ----------------------------------------------------------------------------
# Enable debug mode (verbose logging, additional error details)
DEBUG=false

# Enable auto-reload for development (Streamlit)
MAS_DEV_MODE=false
